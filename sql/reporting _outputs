ORDER BY measure_id, measurement_year;


-- OUTPUT 5: age_band_stratification.csv
SELECT
    measure_id,
    measurement_year,
    age_band,
    denom_count,
    numer_count,
    rate
FROM measure_rate_by_age_band
ORDER BY measure_id, measurement_year, age_band;


