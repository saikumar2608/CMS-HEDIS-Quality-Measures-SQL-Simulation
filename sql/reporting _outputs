-- PDC_DM — 2022 member results
INSERT INTO measure_member_result
       (result_id, run_id, member_id, denominator_flag, numerator_flag,
        exclusion_flag, reason_codes, index_event_dt, measurement_year)
WITH fill_windows AS (
    SELECT p.member_id,
           GREATEST(p.fill_dt,'2022-01-01'::DATE) AS ds,
           LEAST((p.fill_dt + p.days_supply -1)::DATE,'2022-12-31'::DATE) AS de
    FROM pharmacy_claim_fact p JOIN drug_dim d ON p.ndc=d.ndc
    WHERE d.is_antidiabetic_flag=TRUE AND p.fill_dt BETWEEN '2022-01-01' AND '2022-12-31'
),
exploded AS (
    SELECT member_id, generate_series(ds, de, '1 day'::INTERVAL)::DATE AS cd FROM fill_windows
),
unique_days AS (SELECT member_id, cd FROM exploded GROUP BY member_id, cd),
cov_days   AS (SELECT member_id, COUNT(*) AS covered_days FROM unique_days GROUP BY member_id),
fill_cnt   AS (
    SELECT p.member_id, COUNT(*) AS fc, MIN(p.fill_dt) AS first_fill_dt
    FROM pharmacy_claim_fact p JOIN drug_dim d ON p.ndc=d.ndc
    WHERE d.is_antidiabetic_flag=TRUE AND p.fill_dt BETWEEN '2022-01-01' AND '2022-12-31'
    GROUP BY p.member_id
),
enr AS (SELECT DISTINCT member_id FROM eligibility_fact WHERE cov_start_dt<='2022-01-01' AND cov_end_dt>='2022-12-31')
SELECT
    ROW_NUMBER() OVER (ORDER BY f.member_id) + 3000,
    3,
    f.member_id,
    CASE WHEN e.member_id IS NOT NULL AND f.fc>=2 THEN 1 ELSE 0 END,
    CASE WHEN COALESCE(c.covered_days,0)/365.0>=0.80 AND e.member_id IS NOT NULL AND f.fc>=2 THEN 1 ELSE 0 END,
    CASE WHEN e.member_id IS NULL THEN 1 ELSE 0 END,
    CASE WHEN e.member_id IS NULL THEN 'EXCL_ENROLLMENT_GAP'
         WHEN f.fc<2 THEN 'EXCL_INSUFFICIENT_FILLS'
         ELSE 'DENOM_MET' END,
    f.first_fill_dt,
    2022
FROM fill_cnt f
LEFT JOIN cov_days c ON f.member_id=c.member_id
LEFT JOIN enr e      ON f.member_id=e.member_id;


