-- ===========================================================================
-- STEP 3: POPULATE measure_rate_summary  (the key output table)
-- ===========================================================================

INSERT INTO measure_rate_summary (measure_id, measurement_year, denom_count, excl_count, numer_count, rate)
SELECT
    md.measure_id,
    mmr.measurement_year,
    SUM(mmr.denominator_flag)                                         AS denom_count,
    SUM(mmr.exclusion_flag)                                           AS excl_count,
    SUM(mmr.numerator_flag)                                           AS numer_count,
    ROUND(SUM(mmr.numerator_flag)::NUMERIC / NULLIF(SUM(mmr.denominator_flag),0), 4) AS rate
FROM measure_member_result mmr
JOIN measure_run_fact mrf   ON mmr.run_id = mrf.run_id
JOIN measure_dim md         ON mrf.measure_id = md.measure_id
GROUP BY md.measure_id, mmr.measurement_year;

-- Update run_fact with final counts
UPDATE measure_run_fact mrf
SET row_count_denom = mrs.denom_count,
    row_count_numer = mrs.numer_count,
    rate            = mrs.rate
FROM measure_rate_summary mrs
WHERE mrs.measure_id = mrf.measure_id
  AND mrs.measurement_year = (mrf.parameters_json::json->>'measurement_year')::INT;


-- ===========================================================================
-- STEP 4: RATE BY FACILITY (stratification — key for stratified reporting)
-- ===========================================================================

INSERT INTO measure_rate_by_facility
SELECT
    mrf.measure_id,
    mmr.measurement_year,
    ef.facility_id,
    SUM(mmr.denominator_flag) AS denom_count,
    SUM(mmr.numerator_flag)   AS numer_count,
    ROUND(SUM(mmr.numerator_flag)::NUMERIC / NULLIF(SUM(mmr.denominator_flag),0), 4) AS rate
FROM measure_member_result mmr
JOIN measure_run_fact   mrf ON mmr.run_id    = mrf.run_id
JOIN encounter_fact      ef ON ef.member_id  = mmr.member_id
                            AND DATE_PART('year', ef.discharge_dt) = mmr.measurement_year
WHERE ef.facility_id IS NOT NULL
GROUP BY mrf.measure_id, mmr.measurement_year, ef.facility_id;


-- ===========================================================================
-- STEP 5: RATE BY AGE BAND (stratification)
-- ===========================================================================

INSERT INTO measure_rate_by_age_band
SELECT
    mrf.measure_id,
    mmr.measurement_year,
    CASE
        WHEN DATE_PART('year',AGE(mmr.index_event_dt, m.dob)) BETWEEN 18 AND 34 THEN '18-34'
        WHEN DATE_PART('year',AGE(mmr.index_event_dt, m.dob)) BETWEEN 35 AND 49 THEN '35-49'
        WHEN DATE_PART('year',AGE(mmr.index_event_dt, m.dob)) BETWEEN 50 AND 64 THEN '50-64'
        ELSE '65+'
    END AS age_band,
    SUM(mmr.denominator_flag) AS denom_count,
    SUM(mmr.numerator_flag)   AS numer_count,
    ROUND(SUM(mmr.numerator_flag)::NUMERIC / NULLIF(SUM(mmr.denominator_flag),0), 4) AS rate
FROM measure_member_result mmr
JOIN measure_run_fact mrf ON mmr.run_id = mrf.run_id
JOIN member_dim m         ON mmr.member_id = m.member_id
WHERE mmr.index_event_dt IS NOT NULL
GROUP BY mrf.measure_id, mmr.measurement_year,
         CASE
            WHEN DATE_PART('year',AGE(mmr.index_event_dt, m.dob)) BETWEEN 18 AND 34 THEN '18-34'
            WHEN DATE_PART('year',AGE(mmr.index_event_dt, m.dob)) BETWEEN 35 AND 49 THEN '35-49'
            WHEN DATE_PART('year',AGE(mmr.index_event_dt, m.dob)) BETWEEN 50 AND 64 THEN '50-64'
            ELSE '65+'
         END;


-- ===========================================================================
-- STEP 6: YEAR-OVER-YEAR TREND TABLE
-- ===========================================================================

INSERT INTO measure_trend
SELECT
    curr.measure_id,
    curr.measurement_year,
    curr.rate,
    curr.denom_count,
    curr.numer_count,
    ROUND(curr.rate - COALESCE(prior.rate, curr.rate), 4) AS yoy_rate_change
FROM measure_rate_summary curr
LEFT JOIN measure_rate_summary prior
       ON LEFT(prior.measure_id, POSITION('_' IN REVERSE(prior.measure_id)) * -1 + LENGTH(prior.measure_id))
          = LEFT(curr.measure_id, POSITION('_' IN REVERSE(curr.measure_id)) * -1 + LENGTH(curr.measure_id))
      AND prior.measurement_year = curr.measurement_year - 1;


