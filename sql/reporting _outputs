-- ===========================================================================
-- VALIDATION QUERIES — sanity checks before finalizing outputs
-- ===========================================================================

-- Check 1: No member can have numerator=1 without denominator=1
SELECT COUNT(*) AS invalid_numer_without_denom
FROM measure_member_result
WHERE numerator_flag = 1 AND denominator_flag = 0;
-- Expected: 0

-- Check 2: No member can have both exclusion=1 and denominator=1
SELECT COUNT(*) AS invalid_excl_and_denom
FROM measure_member_result
WHERE exclusion_flag = 1 AND denominator_flag = 1;
-- Expected: 0

-- Check 3: Rate summary reconciles to member-level
SELECT
    mrf.measure_id,
    mmr.measurement_year,
    SUM(mmr.denominator_flag) AS member_level_denom,
    mrs.denom_count           AS summary_denom,
    SUM(mmr.denominator_flag) - mrs.denom_count AS discrepancy
FROM measure_member_result mmr
JOIN measure_run_fact mrf     ON mmr.run_id    = mrf.run_id
JOIN measure_rate_summary mrs ON mrs.measure_id = mrf.measure_id
                              AND mrs.measurement_year = mmr.measurement_year
GROUP BY mrf.measure_id, mmr.measurement_year, mrs.denom_count;
-- Expected: discrepancy = 0 for all rows

-- Check 4: All 6 measures have rate summary rows
SELECT COUNT(*) AS measure_rate_rows FROM measure_rate_summary;
-- Expected: 6

-- Check 5: Encounter dates are logically valid (discharge_dt >= admit_dt on same row)
SELECT COUNT(*) AS invalid_encounter_dates
FROM encounter_fact
WHERE enc_type = 'IP'
  AND discharge_dt IS NOT NULL
  AND admit_dt IS NOT NULL
  AND discharge_dt < admit_dt;
-- Expected: 0  (discharge can never be before admission)

