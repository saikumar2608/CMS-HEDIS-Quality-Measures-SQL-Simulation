-- READMIT_30 — 2022 member results
INSERT INTO measure_member_result
       (result_id, run_id, member_id, denominator_flag, numerator_flag,
        exclusion_flag, reason_codes, index_event_dt, measurement_year)
SELECT
    ROW_NUMBER() OVER (ORDER BY e.member_id, e.discharge_dt) + 1000 AS result_id,
    1 AS run_id,
    e.member_id,
    CASE WHEN e.discharge_status NOT IN ('20','30')
          AND e.primary_dx NOT LIKE 'F%'
          AND DATE_PART('year',AGE(e.discharge_dt,m.dob)) >= 18 THEN 1 ELSE 0 END,
    CASE
        WHEN e.discharge_status NOT IN ('20','30')
         AND e.primary_dx NOT LIKE 'F%'
         AND DATE_PART('year',AGE(e.discharge_dt,m.dob)) >= 18
         AND EXISTS (
                SELECT 1 FROM encounter_fact r
                WHERE r.member_id    = e.member_id
                  AND r.enc_type     = 'IP'
                  AND r.encounter_id != e.encounter_id
                  AND r.admit_dt     > e.discharge_dt
                  AND r.admit_dt    <= (e.discharge_dt + INTERVAL '30 days')::DATE
             )
        THEN 1 ELSE 0 END,
    CASE WHEN e.discharge_status IN ('20','30')
          OR e.primary_dx LIKE 'F%'
          OR DATE_PART('year',AGE(e.discharge_dt,m.dob)) < 18 THEN 1 ELSE 0 END,
    CASE WHEN e.discharge_status = '20'               THEN 'EXCL_DEATH'
         WHEN e.discharge_status = '30'               THEN 'EXCL_TRANSFER'
         WHEN e.primary_dx LIKE 'F%'                  THEN 'EXCL_PSYCH_DX'
         WHEN DATE_PART('year',AGE(e.discharge_dt,m.dob)) < 18 THEN 'EXCL_AGE'
         ELSE 'DENOM_MET'
    END,
    e.discharge_dt,
    2022
FROM encounter_fact e
JOIN member_dim m ON e.member_id = m.member_id
WHERE e.enc_type = 'IP'
  AND DATE_PART('year', e.discharge_dt) = 2022
  AND e.discharge_dt IS NOT NULL;


