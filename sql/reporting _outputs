-- OUTPUT 4: yoy_trend.csv
SELECT
    measure_id,
    measurement_year,
    denom_count,
    numer_count,
    rate,
    yoy_rate_change,
    CASE WHEN yoy_rate_change > 0 THEN 'IMPROVED'
         WHEN yoy_rate_change < 0 THEN 'DECLINED'
